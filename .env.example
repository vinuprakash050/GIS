# Backend environment variables
# Copy relevant values to Render's Environment tab (never commit secrets)

# Full Neon connection string (recommended — single var covers everything)
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-xxx.neon.tech/neondb?sslmode=require

# Comma-separated allowed CORS origins
# Add your Vercel frontend URL here once deployed
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173,http://localhost:4173

# Frontend environment variables (set in Vercel project settings)
VITE_API_BASE_URL=https://gis-mvp-api.onrender.com
